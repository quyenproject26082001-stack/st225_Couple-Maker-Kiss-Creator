<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".ui.trending.TrendingActivity">

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <ImageView
        android:id="@+id/bg_cvimage"
        android:layout_width="match_parent"
        android:layout_height="0dp"

        android:background="@drawable/bg_cus"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@id/cvImage" />

    <!--    cvImage-->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="46dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="16dp"
        android:visibility="visible"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="4dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        app:strokeColor="#166086"
        tools:context=".ui.trending.TrendingActivity">

        <!--        imvImage-->
        <ImageView
            android:id="@+id/imvImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="center" />

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="28dp"

            android:layout_height="28dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="19dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ic_edit_trending"
            android:visibility="gone" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/guidRandom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/guid_random">

            <!-- Guideline tại 70% từ top -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.4" /> <!-- 70% từ top = 30% từ bottom -->

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:fontFamily="@font/cherry_bomb_regular"
                android:gravity="center"
                android:text="@string/click_the_random_button_below_to_see_what_your_character_is"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" /> <!-- bottom của text = guideline -->

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cvImage">

        <FrameLayout
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_random_cosplay"
            app:layout_constraintDimensionRatio="328:56">


            <TextView
                android:id="@+id/tvRandom"
                style="@style/single_marquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"

                android:fontFamily="@font/cherry_bomb_regular"
                android:gravity="center"
                android:text="@string/random"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="visible" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnCosPlay"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_cosplay"
            app:layout_constraintDimensionRatio="328:56">


            <TextView
                android:id="@+id/tvCosplay"
                style="@style/single_marquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"

                android:fontFamily="@font/cherry_bomb_regular"
                android:gravity="center"
                android:text="@string/playcos"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="visible" />
        </FrameLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>